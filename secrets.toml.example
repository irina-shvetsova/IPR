# Скопируйте этот файл в .streamlit/secrets.toml и заполните.
# Реальный secrets.toml в репозиторий попадать не должен (см. .gitignore).

# Доступ к DeepSeek через Яндекс Клауд (AI Studio / Foundation Models)
YANDEX_API_KEY  = "AQVN..."        # ключ сервисного аккаунта с ролью ai.languageModels.user
YANDEX_FOLDER_ID = "b1g..."         # идентификатор каталога
YANDEX_MODEL_ID = "deepseek-v3"     # точный id модели из Model Gallery (проверьте в консоли)
